---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Sidebar from "../../components/Sidebar.astro";
import { SITE_TITLE } from "../../consts";
import raw from "./books.csv?raw";

const lines = raw
	.trim()
	.split("\n")
	.filter((line) => line.trim() !== "");
const headers = lines[0].split(",");
const books = lines.slice(1).map((line) => {
	const values = line.split(",");
	return Object.fromEntries(
		headers.map((h, i) => [h.trim(), values[i]?.trim() ?? ""]),
	);
});
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`蔵書一覧(工事中) | ${SITE_TITLE}`} description="持ってる本の一覧" />
		<style>
			h1 {
				font-size: 2rem;
				margin-bottom: 1rem;
			}
		</style>
	</head>
	<body>
			<Header />
		<div class="layout-wrapper">
		<main>
			<h1>蔵書一覧(工事中)</h1>
			<p>僕の持ってる本の一覧、読みたい人がいれば貸します。</p>
			<div style="margin-left: 2rem;">
				{
					books.map((book) => (
						<div style="display: flex; align-items: flex-start; margin-bottom: 2rem;">
							<img
								src={`https://books.google.com/books/content?vid=ISBN${book.ISBN}&printsec=frontcover&img=1&zoom=1`}
								alt={book.title}
								width="100"
								height="150"
							/>
							<div style="margin-bottom: 2rem; margin-left: 2rem;">
								<h2>{book.title} </h2>
								<p style="margin-left: 2rem;">
									著者: {book.author}
								</p>
								<p style="margin-left: 2rem;">{book.comment}</p>
							</div>
						</div>
					))
				}
			</div>
			<p>表紙画像はGoogle Booksから取得しています。</p>
		</main>
		<Sidebar />
	</div>
	<Footer />
	</body>
</html>
