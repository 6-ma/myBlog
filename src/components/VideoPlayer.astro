---
/**
 * VideoPlayer.astro
 * クリックするまで動画を読み込まない遅延ロードプレイヤー。
 * 再生開始後、動画のメタデータから縦横比を自動取得して調整する。
 */

interface Props {
    /** 動画ファイルの URL */
    src: string;
    /** サムネイル画像の URL（省略可） */
    poster?: string;
    /** 動画タイトル（省略可） */
    title?: string;
    /** 再生時間の表示、例: "3:42"（省略可） */
    duration?: string;
    /**
     * 動画読み込み前のアスペクト比（デフォルト: "16/9"）。
     * 読み込み後は動画の実寸から自動調整される。
     */
    aspectRatio?: string;
}

const { src, poster, title, duration, aspectRatio = "16/9" } = Astro.props;

const uid = `vp-${Math.random().toString(36).slice(2, 8)}`;
---

<div
    class="video-player"
    id={uid}
    data-src={src}
    style={`aspect-ratio: ${aspectRatio}`}
    role="button"
    tabindex="0"
    aria-label={title ? `${title}を再生` : "動画を再生"}
>
    <!-- サムネイル -->
    {
        poster ? (
            <img
                class="video-player__poster"
                src={poster}
                alt={title ?? ""}
                loading="lazy"
                decoding="async"
            />
        ) : (
            <div
                class="video-player__poster video-player__poster--empty"
                aria-hidden="true"
            />
        )
    }

    <!-- 再生ボタン + メタ情報オーバーレイ -->
    <div class="video-player__overlay" aria-hidden="true">
        <div class="video-player__play-btn">
            <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                width="22"
                height="22"
                aria-hidden="true"
            >
                <path d="M8 5.14v14l11-7-11-7z"></path>
            </svg>
        </div>

        {
            (title || duration) && (
                <div class="video-player__meta">
                    {title && <span class="video-player__title">{title}</span>}
                    {duration && (
                        <span class="video-player__duration">{duration}</span>
                    )}
                </div>
            )
        }
    </div>
</div>

<style>
    /* ── ラッパー ── */
    .video-player {
        position: relative;
        width: 100%;
        display: block;
        background: rgb(var(--gray-light));
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        box-shadow: var(--box-shadow);
        outline: none;
        /* クリック時の青いハイライトを消す（モバイル） */
        -webkit-tap-highlight-color: transparent;
    }

    .video-player:focus-visible {
        box-shadow:
            0 0 0 3px rgba(var(--gray), 0.4),
            var(--box-shadow);
    }

    /* ── サムネイル ── */
    .video-player__poster {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition:
            opacity 0.25s ease,
            transform 0.3s ease;
    }

    .video-player__poster--empty {
        background: linear-gradient(
            135deg,
            rgb(var(--gray-light)) 0%,
            rgba(var(--gray), 0.15) 100%
        );
    }

    .video-player:hover .video-player__poster {
        opacity: 0.8;
        transform: scale(1.02);
    }

    /* ── オーバーレイ（再生ボタン + メタ情報を含む） ── */
    .video-player__overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    /* ── 再生ボタン ── */
    .video-player__play-btn {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--accent);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        /* アイコンを視覚的に中央へ */
        padding-left: 3px;
        transition:
            background 0.2s ease,
            transform 0.2s ease,
            box-shadow 0.2s ease;
        box-shadow: 0 2px 12px rgba(35, 55, 255, 0.4);
    }

    .video-player:hover .video-player__play-btn {
        background: var(--accent-dark);
        transform: scale(1.1);
        box-shadow: 0 4px 20px rgba(35, 55, 255, 0.55);
    }

    /* ── タイトル・再生時間バー ── */
    .video-player__meta {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 40px 14px 12px;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.6) 0%,
            transparent 100%
        );
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 8px;
    }

    .video-player__title {
        color: #fff;
        font-size: 0.8125rem;
        font-weight: 500;
        line-height: 1.3;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .video-player__duration {
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.75rem;
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.03em;
        flex-shrink: 0;
        background: rgba(0, 0, 0, 0.4);
        padding: 2px 6px;
        border-radius: 3px;
    }

    /* ── 再生中: サムネイルとオーバーレイを非表示 ── */
    .video-player.is-playing .video-player__poster,
    .video-player.is-playing .video-player__overlay {
        display: none;
    }

    /* ── 埋め込み video 要素 ── */
    .video-player video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        background: #000;
    }
</style>

<script>
    function initVideoPlayers() {
        document
            .querySelectorAll<HTMLElement>(".video-player:not([data-init])")
            .forEach((player) => {
                player.dataset.init = "1";

                const activate = () => {
                    if (player.classList.contains("is-playing")) return;

                    const src = player.dataset.src;
                    if (!src) return;

                    const video = document.createElement("video");
                    video.src = src;
                    video.controls = true;
                    video.autoplay = true;
                    video.playsInline = true;
                    video.preload = "auto";

                    // 動画の実寸からアスペクト比を自動更新
                    video.addEventListener("loadedmetadata", () => {
                        const { videoWidth, videoHeight } = video;
                        if (videoWidth && videoHeight) {
                            player.style.aspectRatio = `${videoWidth} / ${videoHeight}`;
                        }
                    });

                    player.classList.add("is-playing");
                    player.appendChild(video);
                    video.play().catch(() => {
                        // autoplay がブロックされた場合はコントロール表示のままユーザーに委ねる
                    });
                };

                player.addEventListener("click", activate);
                player.addEventListener("keydown", (e) => {
                    if (e.key === "Enter" || e.key === " ") {
                        e.preventDefault();
                        activate();
                    }
                });
            });
    }

    initVideoPlayers();

    // Astro View Transitions 対応
    document.addEventListener("astro:page-load", initVideoPlayers);
</script>
